# Hanya izinkan akses file gambar
<FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
    Require all granted
</FilesMatch>

# Blok semua file lain
<FilesMatch "\.php$">
    Require all denied
</FilesMatch>

# Disable directory listing
Options -Indexes

# Disable PHP execution (Komentari jika menyebabkan error 500 di hosting PHP-FPM)
# php_flag engine off
